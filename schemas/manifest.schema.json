{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prd.eonhive.dev/schemas/manifest.schema.json",
  "title": "PRD Manifest",
  "description": "Canonical manifest schema for the first executable PRD foundation. The manifest remains the canonical package control surface.",
  "type": "object",
  "required": [
    "prdVersion",
    "manifestVersion",
    "id",
    "profile",
    "title",
    "entry"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "prdVersion": {
      "type": "string",
      "minLength": 1
    },
    "manifestVersion": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "pattern": "^[a-z0-9-]+(?:\\.[a-z0-9-]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "entry": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        { "not": { "pattern": "^/" } },
        { "not": { "pattern": "\\\\" } },
        { "not": { "pattern": "(^|/)\\.\\.(?:/|$)" } },
        { "not": { "pattern": "^[a-zA-Z][a-zA-Z0-9+.-]*:" } },
        { "not": { "pattern": "/$" } }
      ]
    },
    "profileVersion": {
      "type": "string",
      "minLength": 1
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "public": {
      "$ref": "#/$defs/publicMetadata"
    },
    "localization": {
      "$ref": "#/$defs/localization"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/assetDeclaration" }
    },
    "attachments": {
      "type": "array",
      "items": { "$ref": "#/$defs/attachmentDeclaration" }
    },
    "extensions": {
      "oneOf": [
        {
          "type": "array",
          "items": { "$ref": "#/$defs/extensionDeclaration" }
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "protected": {
      "$ref": "#/$defs/protectedDeclaration"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "profile": {
            "enum": ["general-document", "responsive-document"]
          }
        },
        "required": ["profile"]
      },
      "then": {
        "properties": {
          "entry": {
            "pattern": "^content/.+\\.json$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile": {
            "enum": ["comic", "storyboard"]
          }
        },
        "required": ["profile"]
      },
      "then": {
        "properties": {
          "entry": {
            "pattern": "^content/.+\\.(json|html?)$"
          }
        }
      }
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonEmptyStringArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "identity": {
      "type": "object",
      "properties": {
        "revisionId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "parentId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "originId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "authorRefs": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "publisherRef": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "ownerRef": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "series": {
          "$ref": "#/$defs/identitySeriesMembership"
        },
        "collections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/identityCollectionMembership"
          }
        }
      },
      "additionalProperties": true
    },
    "seriesSequence": {
      "type": "object",
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "volume": {
          "type": "integer",
          "minimum": 1
        },
        "issue": {
          "type": "integer",
          "minimum": 1
        },
        "chapter": {
          "type": "integer",
          "minimum": 1
        },
        "episode": {
          "type": "integer",
          "minimum": 1
        },
        "part": {
          "type": "integer",
          "minimum": 1
        }
      },
      "anyOf": [
        { "required": ["index"] },
        { "required": ["volume"] },
        { "required": ["issue"] },
        { "required": ["chapter"] },
        { "required": ["episode"] },
        { "required": ["part"] }
      ],
      "additionalProperties": true
    },
    "identitySeriesMembership": {
      "type": "object",
      "required": ["ref"],
      "properties": {
        "ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "sequence": {
          "$ref": "#/$defs/seriesSequence"
        }
      },
      "additionalProperties": true
    },
    "identityCollectionMembership": {
      "type": "object",
      "required": ["ref"],
      "properties": {
        "ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "publicContributor": {
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "role": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "displayName": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "publicMetadata": {
      "type": "object",
      "properties": {
        "subtitle": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "byline": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "contributors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/publicContributor"
          }
        },
        "publisher": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "genres": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "subgenres": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "tags": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "contentWarnings": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "contentRating": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "cover": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "series": {
          "$ref": "#/$defs/publicSeriesMetadata"
        },
        "collections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/publicCollectionMetadata"
          }
        }
      },
      "additionalProperties": true
    },
    "publicSeriesMetadata": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "publicCollectionMetadata": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "localization": {
      "type": "object",
      "required": ["defaultLocale"],
      "properties": {
        "defaultLocale": {
          "type": "string",
          "minLength": 1
        },
        "availableLocales": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "textDirection": {
          "type": "string",
          "enum": ["ltr", "rtl", "auto"]
        }
      },
      "additionalProperties": true
    },
    "capabilityLists": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "minViewer": {
          "type": "string",
          "minLength": 1
        },
        "capabilities": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            { "$ref": "#/$defs/capabilityLists" }
          ]
        }
      },
      "additionalProperties": true
    },
    "assetDeclaration": {
      "type": "object",
      "required": ["href"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1,
          "allOf": [
            { "not": { "pattern": "^/" } },
            { "not": { "pattern": "\\\\" } },
            { "not": { "pattern": "(^|/)\\.\\.(?:/|$)" } },
            { "not": { "pattern": "^[a-zA-Z][a-zA-Z0-9+.-]*:" } },
            { "pattern": "^assets/.+" }
          ]
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "attachmentDeclaration": {
      "type": "object",
      "required": ["href"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "extensionDeclaration": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "protectedDeclaration": {
      "type": "object",
      "properties": {
        "present": {
          "type": "boolean"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  }
}
